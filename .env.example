# Public hostname users will browse to (e.g. alley.fastlanedev.com).
# TLS is terminated by an upstream nginx on a different server; that nginx
# must already be configured to forward this host:8065 with X-Forwarded-Proto
# and X-Forwarded-For set. See SETUP.md "Upstream nginx".
DOMAIN=alley.fastlanedev.com

# Timezone for all containers in the stack.
TZ=UTC

# Postgres password used by Mattermost and the backup jobs. Change before
# first boot. Generate with:  openssl rand -base64 32
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Name shown in browser tab, login page, and baked into translation files
# at image build time. Logos/favicons go in ./branding/ — see branding/README.md.
SITE_NAME=Rally

# Optional: interface to bind 8065 on. Default 0.0.0.0 (all interfaces).
# Set to a Tailscale or private IP if 8065 should not be reachable on the
# public internet — e.g. BIND_ADDR=100.65.16.16
BIND_ADDR=0.0.0.0

# Optional: LAN IP of this machine, for testing the mobile app against the
# dev stack (docker-compose.local.yml on :8066) over wifi. Prod ignores it.
LAN_IP=

# --- AWS SES (SMTP) -----------------------------------------------------------
# Used for email invites + Mattermost notifications. Without these, the
# "Preview Mode: Email notifications have not been configured" banner stays
# up and email-invite flows don't work. See SETUP.md "Phase 5 — Email (AWS SES)".

SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=

# Envelope From + Reply-To for all Mattermost-sent mail. Must be on a domain
# you've verified in SES.
SES_FROM_ADDRESS=noreply@alley.fastlanedev.com

# --- Backups ------------------------------------------------------------------
# S3 destination for both postgres dumps (hourly tier) and restic snapshots
# of the uploaded-files volume (daily). Same bucket as the emailpipeline
# backups, different prefix.
S3_BACKUP_BUCKET=racecamp-db-backups
S3_BACKUP_REGION=us-east-1
S3_BACKUP_KEY_ID=
S3_BACKUP_KEY_SECRET=

# Restic repository encryption password. LOSE THIS AND THE FILE BACKUPS ARE
# UNRECOVERABLE — save it to a password manager the moment you generate it.
# Generate with:  openssl rand -base64 48
RESTIC_PASSWORD=
