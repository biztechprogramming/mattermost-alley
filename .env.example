# Public hostname users will browse to (e.g. chat.example.com).
# Must point at this server's public IP via DNS before first boot, so Caddy can get TLS.
DOMAIN=chat.example.com

# Email passed to Let's Encrypt for expiry notifications.
ACME_EMAIL=you@example.com

# Timezone for the Mattermost container.
TZ=UTC

# Postgres password used by the Mattermost container. Change before first boot.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Name to use in place of "Mattermost" — shown in the browser tab, login page,
# and baked into translation files at image build time. Pick something short
# and memorable. Logos/favicons go in ./branding/ — see branding/README.md.
SITE_NAME=Rally

# Optional: LAN IP of this machine, for testing the mobile app against the
# local stack over wifi (e.g. 192.168.1.42). Leave unset for localhost-only.
# Find it with: hostname -I  (or `ip -4 addr show | grep inet`)
# Only used by docker-compose.local.yml — prod ignores it.
LAN_IP=

# --- AWS SES (SMTP) -----------------------------------------------------------
# Used for email invites + Mattermost notifications. Without these, the
# "Preview Mode: Email notifications have not been configured" banner stays
# up and email-invite flows don't work. See SETUP.md "Phase 5 — Email (AWS SES)".
#
# Setup summary (full walkthrough in SETUP.md):
#   1. Verify your sending domain in SES (us-east-1) — publish the 3 DKIM
#      CNAMEs SES gives you to the parent zone (e.g. fastlanedev.com).
#   2. SES console → SMTP settings → Create SMTP credentials. SES creates an
#      IAM user and gives you a paired SMTP username/password — these are
#      NOT your AWS access key / secret. Paste them below.
#   3. Sandbox mode: also verify each invitee's email under "Verified
#      identities" before inviting them, OR request production access.

SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=

# Envelope From + Reply-To for all Mattermost-sent mail. Must be on a domain
# you've verified in SES. Stick with `noreply@<your-domain>` unless you have
# a reason to change it.
SES_FROM_ADDRESS=noreply@alley.fastlanedev.com
